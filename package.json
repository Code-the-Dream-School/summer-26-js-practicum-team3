{
  "name": "summer-26-js-practicum-team3",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "format:frontend": "npm run format --workspace=frontend",
    "format:backend": "npm run format --workspace=backend",
    "format": "concurrently \"npm:format:*\"",
    "init-env": "cp -n backend/.env.example backend/.env && cp -n frontend/.env.example frontend/.env",
    "db:generate":"npm run --workspace=backend db:generate"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "prettier": "3.9.5"
  }
}
